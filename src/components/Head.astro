---
// Starlight `Head` component override: renders the same tags Starlight would
// (site config `head` + per-page frontmatter `head`, merged upstream), plus
// JSON-LD structured data derived from the current route. Kept as a thin
// wrapper — see https://starlight.astro.build/reference/overrides/#head.
import Default from '@astrojs/starlight/components/Head.astro';

const { entry, lastUpdated, lang, locale, siteTitle } = Astro.locals.starlightRoute;
const { title, description } = entry.data;

const SITE = 'https://tulparlang.dev';
const pathname = Astro.url.pathname;
const canonicalUrl = new URL(pathname, SITE).toString();

// Path segments with the locale prefix removed, so breadcrumbs read the
// same shape regardless of locale (e.g. /tr/guide/tulpar-vs-c/ -> ["guide", "tulpar-vs-c"]).
const segments = pathname.split('/').filter(Boolean).filter((s) => s !== locale);
const isHome = segments.length === 0;
const homeUrl = `${SITE}${locale ? '/' + locale + '/' : '/'}`;

// Docs are exactly two segments deep (category/page) and categories (guide/,
// stdlib/, ...) have no standalone landing page, so a middle crumb would
// point at a URL that 404s. Google's guidance is every non-final ListItem
// needs a real `item` URL, so we only emit Home -> current page.
const breadcrumbList = !isHome && {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: homeUrl },
		{ '@type': 'ListItem', position: 2, name: title, item: canonicalUrl },
	],
};

const sameAs = ['https://github.com/hamer1818/TulparLang', 'https://pkg.tulparlang.dev'];

// Organization + SoftwareSourceCode only need to appear once — the homepage
// is the canonical place for entity-establishing schema.
const organizationSchema = isHome && {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	'@id': `${SITE}/#organization`,
	name: 'Tulpar Language',
	url: SITE,
	logo: `${SITE}/icon.png`,
	sameAs,
};

const softwareSchema = isHome && {
	'@context': 'https://schema.org',
	'@type': 'SoftwareSourceCode',
	name: 'Tulpar',
	description,
	codeRepository: 'https://github.com/hamer1818/TulparLang',
	programmingLanguage: 'Tulpar',
	runtimePlatform: 'LLVM',
	license: 'https://github.com/hamer1818/TulparLang/blob/main/LICENSE',
	author: { '@id': `${SITE}/#organization` },
};

const pageSchema = {
	'@context': 'https://schema.org',
	'@type': isHome ? 'WebSite' : 'TechArticle',
	name: isHome ? siteTitle : title,
	headline: title,
	description,
	url: canonicalUrl,
	inLanguage: lang,
	...(isHome ? { publisher: { '@id': `${SITE}/#organization` } } : {}),
	...(lastUpdated ? { dateModified: lastUpdated.toISOString() } : {}),
};

const jsonLdBlocks = [organizationSchema, softwareSchema, pageSchema, breadcrumbList].filter(Boolean);
---

<Default {...Astro.props}><slot /></Default>
{jsonLdBlocks.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
